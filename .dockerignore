# Test files
tests/
phpunit.xml
.phpunit.result.cache

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# Documentation
README.md
*.md

# Environment files (we use env vars from Cloud Run)
.env
.env.*
!.env.example

# Logs
*.log
storage/logs/*

# Cache
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*

# Node modules (if any)
node_modules/

# PHP dependencies — the image builds its own --no-dev vendor.
# Never copy the host vendor in: it carries dev-only packages (e.g. laravel/pail)
# in installed.json that `dump-autoload --no-dev` then strips from the autoloader,
# causing "Class Laravel\Pail\PailServiceProvider not found" at boot.
vendor/

# Local Docker dev — never bake compose files or DB dumps into the prod image
docker-compose.yml
docker-compose.*.yml
.docker/mysql/init/*.sql
scripts/

# Build artifacts
bootstrap/cache/*
!bootstrap/cache/.gitignore

