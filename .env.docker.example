# =============================================================================
# LOCAL DOCKER ENV — copy to .env.docker and fill in the secrets.
#   copy .env.docker.example .env.docker
# Loaded by docker-compose (env_file) into the app container at runtime.
# The image itself contains NO .env (.dockerignore excludes it) — config comes
# from these variables, exactly like Railway.
# =============================================================================

APP_NAME=GymHubPH
APP_ENV=local
# Reuse the local dev key from .env.example. Generate a fresh one with:
#   docker compose run --rm app php artisan key:generate --show
APP_KEY=base64:eXyAz7Zj3cKaWXV6SQkv65zLQBmLxruM0EtwL1mfFjg=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Manila
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

# Local dev logging (APP_ENV=local -> daily file logs inside the container).
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database -----------------------------------------------------------------
# DB_HOST is overridden to "mysql" by docker-compose. Credentials are shared with
# the travelsystem/mymeds local stacks so a single Navicat connection works for
# all of them. (root is also available passwordless for admin.)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=triforceph
DB_USERNAME=user
DB_PASSWORD=Abc_12345

# --- Laravel infra drivers (all DB-backed, tables come from migrations/dump) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- New Relic: keep OFF locally so the APM agent stays silent -----------------
NEW_RELIC_ENABLED=false
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=GymHubPH-local

# --- Mail (MailerSend sandbox — safe for local) -------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailersend.net
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@localhost
MAIL_FROM_NAME=GymHubPH

# --- Firebase Auth (REQUIRED for login/signup to work locally) ----------------
# Paste the service-account JSON as a single-line string, or leave blank if you
# only need endpoints that don't hit FirebaseAuthMiddleware.
FIREBASE_CREDENTIALS=

# --- Cloudflare R2 (file storage — optional locally, FILESYSTEM_DISK=local) ---
R2_ACCOUNT_ID=
R2_BUCKET=
R2_PUBLIC_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Frontend origin (used for verification links, etc.)
FRONTEND_URL=http://localhost:5173
